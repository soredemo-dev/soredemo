{
  "name": "soredemo",
  "version": "0.1.0-alpha.0",
  "description": "Turn declarative YAML into polished product demos of real web apps.",
  "type": "module",
  "bin": {
    "soredemo": "./dist/cli.js"
  },
  "files": [
    "assets",
    "CHANGELOG.md",
    "dist",
    "schema"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && node scripts/finalize-dist.mjs && node dist/schema/generate-json-schema.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "npm run build",
    "soredemo": "node dist/cli.js",
    "spike:day2": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day2-capture-spike.js",
    "spike:day3": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day3-click-gate.js",
    "spike:day4": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day4-resampler-spike.js",
    "spike:day5": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day5-compositor-spike.js",
    "spike:day6": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day6-cursor-landing-gate.js",
    "spike:day7": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day7-camera-spike.js",
    "spike:day8": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day8-studio-composition.js",
    "spike:day9": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day9-ffmpeg-encode.js",
    "fixture:server": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day10-fixture-server.js",
    "gate:cursor-sync": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day10-cursor-sync-gate.js",
    "gate:signals": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/day11-signal-gate.js",
    "golden:inputs": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/golden-inputs.js",
    "golden:generate": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/golden-authority.js generate",
    "golden:verify-candidate": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/golden-authority.js verify-candidate",
    "golden:promote": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/golden-authority.js promote",
    "golden:verify": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/golden-authority.js verify",
    "live-visual:verify": "corepack pnpm build && tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/live-visual-verify.js",
    "docs:verify": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/verify-doc-snippets.js",
    "licenses:prod": "corepack pnpm licenses list --prod --json",
    "release:check": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/release-candidate.js check",
    "release:pack": "tsc -p tsconfig.scripts.json && node .tmp/day2-build/scripts/release-candidate.js pack",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.19.4 <21"
  },
  "packageManager": "pnpm@10.34.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soredemo-dev/soredemo.git"
  },
  "bugs": {
    "url": "https://github.com/soredemo-dev/soredemo/issues"
  },
  "homepage": "https://github.com/soredemo-dev/soredemo#readme",
  "keywords": [
    "browser-automation",
    "cli",
    "demo",
    "playwright",
    "video"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@napi-rs/canvas": "1.0.2",
    "bezier-easing": "3.0.1",
    "citty": "^0.2.2",
    "ghost-cursor": "1.4.2",
    "js-yaml": "^5.2.1",
    "playwright": "1.61.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.43",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
