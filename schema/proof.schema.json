{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "producer": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "soredemo"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name",
        "version"
      ],
      "additionalProperties": false
    },
    "proofLevel": {
      "type": "string",
      "enum": [
        "verified-live",
        "encoded-verified"
      ]
    },
    "planSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "configSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "outputMp4Sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "files": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "completed": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "producer",
    "proofLevel",
    "planSha256",
    "configSha256",
    "outputMp4Sha256",
    "files",
    "completed"
  ],
  "additionalProperties": false
}
